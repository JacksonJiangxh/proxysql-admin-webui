# ProxySQL Admin WebUI — 环境变量配置
#
# 复制此文件为 .env 并修改相应配置：
#   cp .env.example .env
#
# .env 文件查找顺序（所有部署模式统一）：
#   1. ENV_FILE 环境变量指定的路径
#   2. 当前工作目录下的 .env
#   3. 项目根目录下的 .env
#
# 适用场景：
#   • 开发模式（make run）     — 项目根目录下放置 .env
#   • 二进制部署（单文件）      — 与可执行文件同目录放置 .env
#   • Docker 部署（docker compose） — 项目根目录下放置 .env

# Security — 生产环境必须修改！
SECRET_KEY=change-me-in-production-min-32-chars!!
FERNET_KEY=02F01gw2gjGLev9LC_hGdPYx4cyU4qEAyWWAA4Pa85g=

# Database
DATABASE_URL=sqlite:///data/app.db

# Auth
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — 逗号分隔多个 origin，同时支持开发和生产
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# Logging
LOG_LEVEL=INFO

# ProxySQL defaults
PROXYSQL_DEFAULT_HOST=127.0.0.1
PROXYSQL_DEFAULT_PORT=6032

# Initial admin credentials
PROXYWEB_ADMIN_USER=admin
PROXYWEB_ADMIN_PASSWORD=admin

# ── Rate Limiting ─────────────────────────────────────
# Set to "false" to disable rate limiting (debugging only)
RATE_LIMIT_ENABLED=true
# Global rate limit (per IP)
RATE_LIMIT_GLOBAL_MAX=100
RATE_LIMIT_GLOBAL_WINDOW=60
# Per-endpoint rate limits
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW=60
RATE_LIMIT_WIZARD_MAX=10
RATE_LIMIT_WIZARD_WINDOW=60
RATE_LIMIT_QUERY_MAX=20
RATE_LIMIT_QUERY_WINDOW=60

# ── Server-side Cache ───────────────────────────────────
# In-memory TTLCache reduces repeated ProxySQL queries.
# Set to "false" to disable (e.g., for debugging freshness issues).
CACHE_ENABLED=true
# Dashboard snapshot cache TTL (seconds). Data is ephemeral — keep short.
CACHE_TTL_DASHBOARD=10
# Config diff cache TTL (seconds). Invalidated on sync operations.
CACHE_TTL_CONFIG_DIFF=60

# ── Request Size Limit ──────────────────────────────────
# Maximum request body size in bytes (default: 10 MB).
# Increase this for large file upload scenarios.
# MAX_REQUEST_BODY_SIZE=10485760

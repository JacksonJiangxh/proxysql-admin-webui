# =========================================================================
# ProxySQL Admin WebUI — 环境变量配置（中文说明版）
# =========================================================================
#
# 第一步：复制此文件为 .env
#   cp .env.example .env
#
# 第二步：按照下方说明修改 .env 中的配置值。
#   标有 "⚠ 必须修改" 的项请务必修改，否则存在安全风险！
#
# .env 文件查找顺序（所有部署模式统一）：
#   1. ENV_FILE 环境变量指定的路径
#   2. 当前工作目录下的 .env
#   3. 项目根目录下的 .env
#
# 适用场景：
#   • 开发模式（make run）              — 项目根目录下放置 .env
#   • 二进制部署（单文件）               — 与可执行文件同目录放置 .env
#   • Docker 部署（docker compose）     — 项目根目录下放置 .env
#   • 本地 Docker 构建测试（见 scripts/docker-local-test.sh）
#
# =========================================================================
# ⚠ 安全密钥 — 生产环境必须修改！
# =========================================================================
#
# SECRET_KEY：用于 JWT Token 签名的密钥，泄露后攻击者可伪造任意用户身份。
#   要求：长度至少 32 个字符，随机字符串。
#   【在 Shell 中生成随机密钥】：
#     python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#     或
#     openssl rand -base64 32
#
# FERNET_KEY：用于加密 ProxySQL 连接密码等敏感配置的 Fernet 密钥。
#   本质是 32 字节随机数经 URL-safe Base64 编码，可在终端直接生成：
#   【方法一：纯 Shell（推荐，无需 Python 依赖）】：
#     openssl rand -base64 32 | tr '+/' '-_' | cut -c1-44
#   【方法二：Python（需安装 cryptography 包）】：
#     python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   【方法三：使用 dd + base64（兼容性好）】：
#     dd if=/dev/urandom bs=32 count=1 2>/dev/null | base64 | tr '+/' '-_' | cut -c1-44
#
SECRET_KEY=change-me-in-production-min-32-chars!!
FERNET_KEY=02F01gw2gjGLev9LC_hGdPYx4cyU4qEAyWWAA4Pa85g=

# =========================================================================
# 数据库 — 应用元数据存储
# =========================================================================
# 使用 SQLite 存储应用自身的数据（集群配置、用户等），无需额外数据库服务。
# 路径相对于 backend/ 目录或容器内 /app/ 目录。
# 生产环境建议保留 SQLite，无需额外维护。
DATABASE_URL=sqlite:///data/app.db

# =========================================================================
# 认证 — JWT Token 有效期
# =========================================================================
# Access Token 有效期（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Refresh Token 有效期（天）
REFRESH_TOKEN_EXPIRE_DAYS=7

# =========================================================================
# 日志级别
# =========================================================================
# 可选值：DEBUG / INFO / WARNING / ERROR
# 生产环境请使用 INFO 或 WARNING
LOG_LEVEL=INFO

# =========================================================================
# ⚠ ProxySQL 默认连接信息 — 请根据实际环境修改
# =========================================================================
# 以下为 ProxySQL Admin 接口的默认连接参数。
# 在 Web UI 中添加 ProxySQL 节点时会使用这些默认值。
#
# ⚠ 如果您的 ProxySQL admin 用户不是默认的 admin/admin，
#    请务必修改 PROXYSQL_DEFAULT_USER 和 PROXYSQL_DEFAULT_PASSWORD！
#
PROXYSQL_DEFAULT_HOST=127.0.0.1
PROXYSQL_DEFAULT_PORT=6032
PROXYSQL_DEFAULT_USER=admin
PROXYSQL_DEFAULT_PASSWORD=admin

# =========================================================================
# ⚠ Web UI 初始管理员账号 — 首次启动后请修改密码
# =========================================================================
# 首次启动时自动创建的管理员账号。
# 登录后请在 Web UI 中修改密码！
PROXYWEB_ADMIN_USER=admin
PROXYWEB_ADMIN_PASSWORD=admin



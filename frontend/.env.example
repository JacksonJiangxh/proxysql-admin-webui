# Frontend environment variables (Vite)
#
# Copy to .env for local development:
#   cp frontend/.env.example frontend/.env
#
# Prefix with VITE_ for client-side exposure. Non-VITE_ variables
# are only available in vite.config.ts (server-side).

# ── API Base URL ──────────────────────────────────────
# Override the API base URL (default: same-origin, empty string).
# Useful when the backend is on a different host during development.
# VITE_API_BASE_URL=http://localhost:8080

# ── Dev Mode ──────────────────────────────────────────
# Enable development helpers (verbose logging, React devtools, etc.)
# VITE_DEV_MODE=true

# ProxySQL Admin WebUI — 测试环境配置
#
# 用于Docker测试环境（MySQL + ProxySQL）
# 使用方法：
#   ENV_FILE=.env.test make dev-backend
#   ENV_FILE=.env.test make dev-frontend

# Security — 测试环境使用固定值
SECRET_KEY=test-secret-key-min-32-chars!!
FERNET_KEY=02F01gw2gjGLev9LC_hGdPYx4cyU4qEAyWWAA4Pa85g=

# Database — 使用SQLite作为应用元数据库
DATABASE_URL=sqlite:///data/app_test.db

# Auth
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Logging — 测试环境使用DEBUG级别
LOG_LEVEL=DEBUG

# ProxySQL defaults — 连接到Docker中的ProxySQL
PROXYSQL_DEFAULT_HOST=127.0.0.1
PROXYSQL_DEFAULT_PORT=6032
PROXYSQL_DEFAULT_USER=proxysql_remote
PROXYSQL_DEFAULT_PASSWORD=remote123

# Initial admin credentials — 测试环境使用固定密码
PROXYWEB_ADMIN_USER=admin
PROXYWEB_ADMIN_PASSWORD=admin123
